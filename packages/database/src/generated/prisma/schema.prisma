// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id              String   @id @default(uuid())
  name            String
  contractAddress String   @unique
  merkleRoot      String
  chainId         Int
  createdAt       DateTime @default(now())

  allowlist AllowList[]
  claims    Claim[]
}

model AllowList {
  id         String @id @default(uuid())
  campaignId String
  wallet     String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, wallet])
  @@index([wallet])
  @@index([campaignId])
}

model Claim {
  id         String   @id @default(uuid())
  campaignId String
  wallet     String
  txHash     String
  claimedAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, wallet])
  @@index([wallet])
  @@index([campaignId])
}
